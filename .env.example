# Supabase (required)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Base44 WhatsApp agent (required) - NEVER commit actual values
BASE44_AGENT_ID=your_base44_agent_id
BASE44_API_KEY=your_base44_api_key
BASE44_WEBHOOK_SECRET=your_hmac_secret_here

# Public URL of this API (used in webhook registration)
VPS_PUBLIC_URL=http://YOUR_SERVER_IP:8080

# Admin endpoint protection
ADMIN_KEY=generate_a_random_32char_string

# CORS (comma-separated list of allowed origins, or * for open)
ALLOWED_ORIGINS=*

# Face matching thresholds (defaults shown)
FACE_MATCH_THRESHOLD=0.50
COMBINED_MATCH_THRESHOLD=0.65
FACE_WEIGHT=0.35
TEXT_WEIGHT=0.65
PHOTO_RETENTION_DAYS=30

# Text match threshold
TEXT_MATCH_THRESHOLD=0.75

# Embeddings model (HuggingFace model ID)
EMBEDDINGS_MODEL=paraphrase-multilingual-mpnet-base-v2

# Optional scraper API keys (leave blank to disable those scrapers)
HOSPITALES_ANON_KEY=
REDAYUDA_ANON_KEY=

# WAHA WhatsApp (legacy, not active in Base44 mode)
WAHA_URL=http://waha:3000
WAHA_API_KEY=
WAHA_WEBHOOK_SECRET=
WAHA_SESSION=default
