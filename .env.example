# ─── Supabase (required) ────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── WAHA WhatsApp (required) ───────────────────────────────────────────────
# Self-hosted WAHA container — WAHA_API_KEY and WAHA_WEBHOOK_SECRET
# can be any random string you choose (they are your own secrets).
WAHA_URL=http://waha:3000
WAHA_API_KEY=change_this_to_any_random_string
WAHA_WEBHOOK_SECRET=change_this_to_any_random_string
WAHA_SESSION=default

# ─── Groq LLM (required for bot conversation logic) ─────────────────────────
# Get a free API key at https://console.groq.com
LLM_API_KEY=your_groq_api_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# ─── Admin endpoint protection ──────────────────────────────────────────────
ADMIN_KEY=generate_a_random_32char_string
ALLOWED_ORIGINS=*

# ─── Matching thresholds (defaults shown — only override if needed) ──────────
FACE_MATCH_THRESHOLD=0.50
TEXT_MATCH_THRESHOLD=0.75
COMBINED_MATCH_THRESHOLD=0.65
FACE_WEIGHT=0.35
TEXT_WEIGHT=0.65
PHOTO_RETENTION_DAYS=30
EMBEDDINGS_MODEL=paraphrase-multilingual-mpnet-base-v2

# ─── External scraper API keys (leave blank to disable that scraper) ─────────
HOSPITALES_ANON_KEY=
REDAYUDA_ANON_KEY=

# Override the hardcoded anon key in pacientes_terremoto.py if it gets rotated.
PACIENTES_TERREMOTO_ANON_KEY=

# Inspect network requests on the Red Solidaria site via DevTools to find this ID.
RED_SOLIDARIA_SHEET_ID=
