# Base de datos
# Para SQLite (desarrollo):
DATABASE_URL=sqlite:///./test.db
# Para PostgreSQL (producción):
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/reune

# WAHA — WhatsApp HTTP API
WAHA_URL=http://localhost:3000
WAHA_SESSION=default
WAHA_API_KEY=
WAHA_WEBHOOK_URL=http://localhost:8000/webhook/waha
WAHA_FREE_TIER=true
WAHA_WEBHOOK_SECRET=

# Bot
ENVIRONMENT=development
PHOTO_MAX_COUNT=5
PHOTO_TTL_SECONDS=60
PHOTO_STORAGE_PATH=media/photos

# DeepSeek (deshabilitado — no modificar hasta nueva instrucción)
DEEPSEEK_API_KEY=
